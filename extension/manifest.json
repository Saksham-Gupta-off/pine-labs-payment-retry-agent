{
  "manifest_version": 3,
  "name": "PaySense — Autonomous Payment Intelligence",
  "version": "1.0.0",
  "description": "Never let a transaction fail. AI-powered payment optimization for Indian e-commerce.",
  "permissions": ["activeTab", "storage", "sidePanel", "notifications"],
  "host_permissions": [
    "https://*.flipkart.com/*",
    "https://*.amazon.in/*",
    "https://*.myntra.com/*",
    "https://*.ajio.com/*",
    "https://*.nykaa.com/*",
    "https://*.swiggy.com/*",
    "https://*.zomato.com/*",
    "https://*.bigbasket.com/*",
    "https://*.jiomart.com/*",
    "https://*.meesho.com/*",
    "https://*.croma.com/*",
    "https://*.tatacliq.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.flipkart.com/*",
        "https://*.amazon.in/*",
        "https://*.myntra.com/*",
        "https://*.ajio.com/*",
        "https://*.nykaa.com/*",
        "https://*.swiggy.com/*",
        "https://*.zomato.com/*",
        "https://*.bigbasket.com/*",
        "https://*.jiomart.com/*",
        "https://*.meesho.com/*",
        "https://*.croma.com/*",
        "https://*.tatacliq.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
